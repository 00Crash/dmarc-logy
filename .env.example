APP_NAME=DMARC analyzátor
APP_URL=http://dmarc.ekostavby.local
ENVIRONMENT=production
TZ=Europe/Prague

POSTGRES_DB=dmarc_logy
POSTGRES_USER=dmarc_logy
POSTGRES_PASSWORD=ZMENTE_SILNE_HESLO_POSTGRES
DATABASE_URL=postgresql+psycopg://dmarc_logy:ZMENTE_SILNE_HESLO_POSTGRES@db:5432/dmarc_logy

REDIS_URL=redis://redis:6379/0

IMAP_HOST=mail.ekostavbylouny.cz
IMAP_PORT=993
IMAP_SSL=true
IMAP_USER=dmarc@ekostavbylouny.info
IMAP_PASSWORD=SEM_DOPLNIT_HESLO_K_MAILBOXU
IMAP_FOLDER=INBOX
IMAP_SEARCH=UNSEEN
IMAP_MARK_SEEN=true
IMAP_IMPORT_ENABLED=true
IMAP_IMPORT_INTERVAL_SECONDS=1800

DMARC_REPORT_ADDRESS=dmarc@ekostavbylouny.info
UPLOAD_MAX_MB=25
SECRET_KEY=SEM_DOPLNIT_NAHODNY_SECRET

AUTH_ENABLED=true
